<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>In Reach Therapy — Clinician Portal</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,400&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:"DM Sans",sans-serif;background:#f0f4f8;min-height:100vh}
.hdr{background:linear-gradient(150deg,#0a5c48,#1a9e75);padding:32px 20px 28px;text-align:center}
.hdr h1{font-family:"Fraunces",serif;font-size:26px;font-weight:300;color:#fff;margin-bottom:4px}
.hdr p{font-size:13px;color:rgba(255,255,255,.7)}
.content{max-width:560px;margin:0 auto;padding:24px 16px}
.team-section{margin-bottom:24px}
.team-label{font-size:10px;font-weight:600;letter-spacing:1px;text-transform:uppercase;color:#64748b;margin-bottom:10px;display:flex;align-items:center;gap:8px}
.team-label::after{content:"";flex:1;height:1px;background:#e2e8f0}
.card-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.person-card{background:#fff;border:1px solid #e2e8f0;border-radius:14px;padding:16px;text-decoration:none;display:flex;align-items:center;gap:12px;transition:all .15s;position:relative;overflow:hidden}
.person-card::before{content:"";position:absolute;top:0;left:0;right:0;height:3px;background:var(--accent,#1a9e75);opacity:0;transition:opacity .15s}
.person-card:hover{border-color:#1a9e75;box-shadow:0 4px 12px rgba(26,158,117,.1);transform:translateY(-1px)}
.person-card:hover::before{opacity:1}
.av{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;flex-shrink:0;color:#fff}
.av.ot{background:linear-gradient(135deg,#0a5c48,#1a9e75)}
.av.speech{background:linear-gradient(135deg,#1e40af,#3b82f6)}
.av.lead{background:linear-gradient(135deg,#7c3aed,#a78bfa)}
.person-info{flex:1;min-width:0}
.person-name{font-size:13px;font-weight:600;color:#0f172a;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.person-role{font-size:11px;color:#64748b;margin-top:1px}
.arrow{font-size:14px;color:#94a3b8;flex-shrink:0}
.footer{text-align:center;padding:24px;font-size:11px;color:#94a3b8}
</style>
</head>
